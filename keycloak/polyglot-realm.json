{
  "id": "polyglot",
  "realm": "polyglot",
  "displayName": "Polyglot",
  "enabled": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "editUsernameAllowed": true,
  "sslRequired": "none",
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "roles": {
    "realm": [
      { "name": "user", "description": "Default role for all signed-up users" },
      { "name": "admin", "description": "Polyglot administrator" }
    ]
  },
  "defaultRole": {
    "name": "user",
    "composite": true,
    "composites": {
      "realm": ["user"]
    }
  },
  "clientScopes": [
    {
      "name": "groups",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-as-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "groups",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "polyglot-frontend",
      "name": "Polyglot Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:5246/swagger/oauth2-redirect.html"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:5246"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200"
      },
      "defaultClientScopes": ["openid", "profile", "email", "groups"],
      "optionalClientScopes": ["offline_access"]
    }
  ],
  "users": [
    {
      "username": "admin@polyglot.local",
      "email": "admin@polyglot.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Polyglot",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin", "user"]
    }
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  }
}
