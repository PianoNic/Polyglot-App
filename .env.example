# Copy to .env and fill in. Used by compose.prod.yml.

# Public origin of the app (Pangolin domain for the frontend)
PUBLIC_URL=https://polyglot.example.com

# OIDC (Pocket ID) — its public URL doubles as the issuer/authority
OIDC_AUTHORITY=https://auth.polyglot.example.com
OIDC_CLIENT_ID=polyglot

# Postgres
POSTGRES_PASSWORD=
POSTGRES_DB=polyglot

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5
CHAT_TITLE_MODEL=mistralai/mistral-nemo

# RustFS (S3-compatible storage)
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=

# Automated Postgres backups (pg_dump -> RustFS, daily)
BACKUP_ENABLED=true
BACKUP_TIME_OF_DAY_UTC=03:00
BACKUP_RETENTION_COUNT=14
BACKUP_S3_BUCKET=polyglot-backups

# Name of the external docker network Pangolin proxies through
PANGOLIN_NETWORK=pangolin
